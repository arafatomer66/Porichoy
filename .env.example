# Server
PORT=3400
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=porichoy
DB_USER=postgres
DB_PASSWORD=postgres
DB_SYNCHRONIZE=true
DB_LOGGING=false

# JWT
JWT_ISSUER=http://localhost:3400
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_DAYS=30

# Session
SESSION_TTL_DAYS=7

# OTP — dev mode returns otp in response body, value is always 123456
OTP_DEV_MODE=true
OTP_DEV_VALUE=123456
OTP_TTL_MINUTES=10

# CORS
CORS_ORIGINS=http://localhost:3401
